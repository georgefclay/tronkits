<%
  // expects: kind, color
  var __k = kind, __c = color;
%>
<% if (__k === 'resistor') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <line x1="2" y1="28" x2="12" y2="28" stroke="#15263A" stroke-width="2" />
    <line x1="44" y1="28" x2="54" y2="28" stroke="#15263A" stroke-width="2" />
    <rect x="12" y="20" width="32" height="16" rx="4" fill="#D9A36A" stroke="#15263A" stroke-width="1.5" />
    <rect x="16" y="20" width="3" height="16" fill="#C9442C" />
    <rect x="22" y="20" width="3" height="16" fill="<%= __c %>" />
    <rect x="28" y="20" width="3" height="16" fill="#E5B043" />
    <rect x="36" y="20" width="3" height="16" fill="#B87333" />
  </svg>
<% } else if (__k === 'ic') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <rect x="14" y="14" width="28" height="28" fill="#15263A" />
    <circle cx="19" cy="19" r="1.5" fill="#F5EFDD" />
    <path d="M 24 14 a 4 4 0 0 0 8 0" fill="none" stroke="#F5EFDD" stroke-width="1" />
    <% [18,24,30,36].forEach(function(y){ %>
      <rect x="8"  y="<%= y - 2 %>" width="6" height="4" fill="#15263A" />
      <rect x="42" y="<%= y - 2 %>" width="6" height="4" fill="#15263A" />
    <% }) %>
    <text x="28" y="32" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="<%= __c %>" font-weight="700">555</text>
  </svg>
<% } else if (__k === 'divider') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <line x1="28" y1="4" x2="28" y2="14" stroke="#15263A" stroke-width="2" />
    <polyline points="28,14 24,18 32,22 24,26 28,30" fill="none" stroke="#15263A" stroke-width="2" stroke-linejoin="round" />
    <polyline points="28,30 24,34 32,38 24,42 28,46" fill="none" stroke="#15263A" stroke-width="2" stroke-linejoin="round" />
    <line x1="28" y1="46" x2="28" y2="54" stroke="#15263A" stroke-width="2" />
    <circle cx="28" cy="30" r="3" fill="<%= __c %>" stroke="#15263A" stroke-width="1.5" />
    <text x="40" y="33" font-family="JetBrains Mono, monospace" font-size="9" fill="#4A5B72">Vout</text>
  </svg>
<% } else if (__k === 'led') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <polygon points="14,14 14,42 38,28" fill="<%= __c %>" stroke="#15263A" stroke-width="2" stroke-linejoin="round" />
    <line x1="38" y1="14" x2="38" y2="42" stroke="#15263A" stroke-width="2" />
    <line x1="6" y1="28" x2="14" y2="28" stroke="#15263A" stroke-width="2" />
    <line x1="38" y1="28" x2="50" y2="28" stroke="#15263A" stroke-width="2" />
    <path d="M 42 10 L 50 4 M 44 6 L 48 4" stroke="<%= __c %>" stroke-width="1.5" stroke-linecap="round" />
    <path d="M 46 14 L 54 8" stroke="<%= __c %>" stroke-width="1.5" stroke-linecap="round" />
  </svg>
<% } else if (__k === 'lock') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <rect x="14" y="26" width="28" height="22" rx="2" fill="<%= __c %>" stroke="#15263A" stroke-width="2" />
    <path d="M 19 26 V 18 a 9 9 0 0 1 18 0 V 26" fill="none" stroke="#15263A" stroke-width="2" />
    <circle cx="28" cy="36" r="3" fill="#15263A" />
    <line x1="28" y1="36" x2="28" y2="42" stroke="#15263A" stroke-width="2" />
  </svg>
<% } else if (__k === 'csv') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <rect x="8" y="10" width="40" height="36" fill="#FFFCF2" stroke="#15263A" stroke-width="2" />
    <line x1="8" y1="20" x2="48" y2="20" stroke="#15263A" stroke-width="1" />
    <line x1="8" y1="28" x2="48" y2="28" stroke="#15263A" stroke-width="1" />
    <line x1="8" y1="36" x2="48" y2="36" stroke="#15263A" stroke-width="1" />
    <line x1="22" y1="10" x2="22" y2="46" stroke="#15263A" stroke-width="1" />
    <line x1="36" y1="10" x2="36" y2="46" stroke="#15263A" stroke-width="1" />
    <rect x="8" y="10" width="40" height="10" fill="<%= __c %>" />
  </svg>
<% } else if (__k === 'ohm') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <text x="28" y="38" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-size="32" fill="<%= __c %>" font-weight="700">Ω</text>
  </svg>
<% } else if (__k === 'box') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <polygon points="28,8 48,18 28,28 8,18" fill="<%= __c %>" stroke="#15263A" stroke-width="1.5" stroke-linejoin="round" />
    <polygon points="8,18 28,28 28,48 8,38" fill="#FFFCF2" stroke="#15263A" stroke-width="1.5" stroke-linejoin="round" />
    <polygon points="48,18 28,28 28,48 48,38" fill="#EDE5CD" stroke="#15263A" stroke-width="1.5" stroke-linejoin="round" />
  </svg>
<% } else if (__k === 'logo') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <polygon points="28,4 49,16 49,40 28,52 7,40 7,16"
             fill="none" stroke="<%= __c %>" stroke-width="2.5" stroke-linejoin="round" />
    <line x1="17" y1="21" x2="39" y2="21" stroke="#15263A" stroke-width="1.5" />
    <line x1="17" y1="35" x2="39" y2="35" stroke="#15263A" stroke-width="1.5" />
    <text x="28" y="32" text-anchor="middle" font-family="Space Grotesk, sans-serif"
          font-size="12" font-weight="700" fill="#15263A" letter-spacing="1">TK</text>
  </svg>
<% } else if (__k === 'project') { %>
  <svg width="56" height="56" viewBox="0 0 56 56" aria-hidden="true">
    <rect x="8" y="10" width="40" height="36" fill="#FFFCF2" stroke="#15263A" stroke-width="2" />
    <line x1="14" y1="20" x2="36" y2="20" stroke="<%= __c %>" stroke-width="2" />
    <line x1="14" y1="28" x2="42" y2="28" stroke="#15263A" stroke-width="1.5" />
    <line x1="14" y1="36" x2="30" y2="36" stroke="#15263A" stroke-width="1.5" />
  </svg>
<% } %>
