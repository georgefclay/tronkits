<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %></title>

  <% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
    <meta name="description" content="<%= metaDescription %>">
  <% } %>

  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
    <link rel="canonical" href="<%= canonicalUrl %>">
  <% } %>

  <%
    // --- Social sharing (Open Graph + Twitter) ---
    // Driven by the same per-route locals as the <title>/description above.
    // og:image is only emitted when a route sets `ogImage`, so pages without a
    // dedicated image don't point crawlers at a broken or wrong picture.
    var __ogUrl   = (typeof canonicalUrl !== 'undefined' && canonicalUrl) ? canonicalUrl : (typeof siteUrl !== 'undefined' ? siteUrl : '');
    var __ogDesc  = (typeof metaDescription !== 'undefined') ? metaDescription : '';
    var __ogImg   = (typeof ogImage !== 'undefined' && ogImage)
                      ? ((/^https?:\/\//.test(ogImage) ? '' : (typeof siteUrl !== 'undefined' ? siteUrl : '')) + ogImage)
                      : '';
  %>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="TronKits">
  <meta property="og:title" content="<%= title %>">
  <% if (__ogDesc) { %><meta property="og:description" content="<%= __ogDesc %>"><% } %>
  <% if (__ogUrl)  { %><meta property="og:url" content="<%= __ogUrl %>"><% } %>
  <% if (__ogImg)  { %>
    <meta property="og:image" content="<%= __ogImg %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
  <% } %>

  <meta name="twitter:card" content="<%= __ogImg ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title" content="<%= title %>">
  <% if (__ogDesc) { %><meta name="twitter:description" content="<%= __ogDesc %>"><% } %>
  <% if (__ogImg)  { %><meta name="twitter:image" content="<%= __ogImg %>"><% } %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Bootstrap retained for legacy utility pages (555, voltage-divider, etc.) -->
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <!-- Site design system — loaded after Bootstrap so .tk-* classes win -->
  <link rel="stylesheet" href="/css/tronkits.css">
  <script src="https://code.jquery.com/jquery-3.5.1.min.js" defer></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js" defer></script>
</head>
<body class="tk-graph-paper">
  <%
    var __page = (typeof currentPage !== 'undefined') ? currentPage : '';
  %>
  <header class="tk-nav">
    <svg class="reg-mark tl" viewBox="0 0 14 14">
      <line x1="0" y1="0" x2="14" y2="0" stroke="#15263A" stroke-width="1" />
      <line x1="0" y1="0" x2="0" y2="14" stroke="#15263A" stroke-width="1" />
    </svg>
    <svg class="reg-mark tr" viewBox="0 0 14 14">
      <line x1="14" y1="0" x2="0" y2="0" stroke="#15263A" stroke-width="1" />
      <line x1="14" y1="0" x2="14" y2="14" stroke="#15263A" stroke-width="1" />
    </svg>

    <a href="/" class="tk-wordmark" aria-label="TronKits home">
      <svg width="29" height="26" viewBox="0 0 28 24" aria-hidden="true">
        <rect x="4" y="4" width="20" height="16" rx="1.5" fill="#15263A" />
        <circle cx="8" cy="8" r="1.2" fill="#F5EFDD" />
        <rect x="6" y="0" width="2" height="6" fill="#15263A" />
        <rect x="13" y="0" width="2" height="6" fill="#15263A" />
        <rect x="20" y="0" width="2" height="6" fill="#15263A" />
        <rect x="6" y="18" width="2" height="6" fill="#15263A" />
        <rect x="13" y="18" width="2" height="6" fill="#15263A" />
        <rect x="20" y="18" width="2" height="6" fill="#15263A" />
        <circle cx="22" cy="16" r="2" fill="#E25C2C" />
      </svg>
      <span class="tk-wordmark__text">Tron<span class="slash">/</span>Kits</span>
    </a>

    <button class="tk-nav__toggle" type="button" aria-label="Toggle navigation" onclick="document.getElementById('tkNavLinks').classList.toggle('is-open')">≡</button>

    <nav id="tkNavLinks" class="tk-nav__links" aria-label="Main">
      <%
        var __links = [
          { id:'home',      label:'Home',      path:'/' },
          { id:'tutorials', label:'Tutorials', path:'/tutorials' },
          { id:'blog',      label:'Blog',      path:'/blog' },
          { id:'utilities', label:'Utilities', path:'/utility' },
          { id:'contact',   label:'Contact',   path:'/contact' }
        ];
      %>
      <% __links.forEach(function(l, i){
           var isActive = (__page === l.id);
      %>
        <a href="<%= l.path %>" class="tk-nav__link<%= isActive ? ' active' : '' %>">
          <span class="num">0<%= i + 1 %></span><span class="label"><%= l.label.toUpperCase() %></span>
        </a>
      <% }) %>
      <a href="/tutorials" class="tk-btn tk-btn--accent tk-btn--sm" style="margin-left:14px">Start Learning →</a>
    </nav>
  </header>

  <main class="tk-main">
