<% var currentPage = 'utilities'; %>
<%- include('../partials/header') %>

<section class="tk-hero--tight" style="padding-bottom:28px">
  <div class="tk-breadcrumb">// HOME / TOOLBOX / OPENSCAD BOX GENERATOR</div>
  <h1 class="tk-h1" style="font-size:64px">Box generator.</h1>
  <p class="tk-lede" style="margin-top:12px; max-width:680px">
    Parametric box generator. Set dimensions, choose square or rounded corners, copy the OpenSCAD code — or render an STL on the server.
  </p>
</section>

<section class="tk-section-tight">
  <div class="tk-2col">
    <div class="tk-card-headed">
      <div class="tk-card-headed__head">
        <span>// INPUT · DIMENSIONS</span>
        <span class="yellow">MM</span>
      </div>
      <div class="tk-card-headed__body" style="padding:24px 26px">
        <div class="tk-calc-grid--2">
          <div class="tk-form-group">
            <label class="tk-label" for="width">// Width</label>
            <div class="tk-input-group">
              <input type="number" id="width" name="width" value="50" class="tk-input">
              <span class="tk-input-suffix">mm</span>
            </div>
          </div>
          <div class="tk-form-group">
            <label class="tk-label" for="length">// Length</label>
            <div class="tk-input-group">
              <input type="number" id="length" name="length" value="40" class="tk-input">
              <span class="tk-input-suffix">mm</span>
            </div>
          </div>
          <div class="tk-form-group">
            <label class="tk-label" for="height">// Height</label>
            <div class="tk-input-group">
              <input type="number" id="height" name="height" value="25" class="tk-input">
              <span class="tk-input-suffix">mm</span>
            </div>
          </div>
          <div class="tk-form-group">
            <label class="tk-label" for="wallThickness">// Wall thickness</label>
            <div class="tk-input-group">
              <input type="number" id="wallThickness" name="wallThickness" value="2" class="tk-input">
              <span class="tk-input-suffix">mm</span>
            </div>
          </div>
          <div class="tk-form-group">
            <label class="tk-label" for="lidThickness">// Lid thickness</label>
            <div class="tk-input-group">
              <input type="number" id="lidThickness" name="lidThickness" value="4" class="tk-input">
              <span class="tk-input-suffix">mm</span>
            </div>
          </div>
          <div class="tk-form-group" style="display:flex; align-items:flex-end">
            <label class="tk-check">
              <input type="checkbox" id="roundCorners" name="roundCorners">
              <span>Rounded corners</span>
            </label>
          </div>
        </div>

        <div class="tk-form-group" id="cornerRadiusDropdownWrapper" style="display:none; margin-top:18px; max-width:260px">
          <label class="tk-label" for="cornerRadiusDropdown">// Corner radius (mm)</label>
          <select id="cornerRadiusDropdown" class="tk-select">
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
          </select>
        </div>

        <div class="tk-hero__btns" style="margin-top:24px; gap:10px">
          <button id="myButton" name="myButton" class="tk-btn tk-btn--accent">Generate OpenSCAD →</button>
          <button id="generateSTL" name="generateSTL" class="tk-btn tk-btn--ghost">Render STL ↓</button>
        </div>
        <div id="scadMsg" class="tk-status-msg"></div>
      </div>
    </div>

    <div class="tk-card-headed">
      <div class="tk-card-headed__head">
        <span>📄 box.scad</span>
        <span class="yellow">· OPENSCAD ·</span>
      </div>
      <div class="tk-card-headed__body" style="padding:0">
        <textarea id="output" class="tk-code-output" rows="22" spellcheck="false" placeholder="Generated code will appear here..."></textarea>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  function sq_box() {
    var sout = sbox.replace("{{w}}",  document.getElementById("width").value);
    sout = sout.replace("{{l}}",  document.getElementById("length").value);
    sout = sout.replace("{{h}}",  document.getElementById("height").value);
    sout = sout.replace("{{wt}}", document.getElementById("wallThickness").value);
    sout = sout.replace("{{lt}}", document.getElementById("lidThickness").value);
    document.getElementById("output").value = sout;
  }
  function rd_box() {
    var sout = rbox.replace("{{w}}",  document.getElementById("width").value);
    sout = sout.replace("{{l}}",  document.getElementById("length").value);
    sout = sout.replace("{{h}}",  document.getElementById("height").value);
    sout = sout.replace("{{wt}}", document.getElementById("wallThickness").value);
    sout = sout.replace("{{lt}}", document.getElementById("lidThickness").value);
    sout = sout.replace("{{cr}}", document.getElementById("cornerRadiusDropdown").value);
    document.getElementById("output").value = sout;
  }

  function showMsg(text, kind) {
    var m = document.getElementById("scadMsg");
    m.className = "tk-status-msg" + (kind ? " is-" + kind : "");
    m.textContent = text;
  }

  $('#myButton').click(function() {
    if ($('#roundCorners').is(':checked')) rd_box(); else sq_box();
    showMsg("OpenSCAD code generated.", "success");
  });
  $('#roundCorners').change(function() {
    $('#cornerRadiusDropdownWrapper').toggle($(this).is(':checked'));
  });

  $('#generateSTL').click(function () {
    const scadCode = document.getElementById("output").value;
    if (!scadCode.trim()) {
      showMsg("Generate OpenSCAD code first.", "warning");
      return;
    }
    showMsg("Rendering STL on server (may take up to 10 min)...", "warning");
    $.ajax({
      url: '/generate-stl',
      method: 'POST',
      contentType: 'application/json',
      data: JSON.stringify({ scad: scadCode }),
      success: function (res) {
        showMsg("STL ready. Downloading...", "success");
        window.location.href = res.url;
      },
      error: function () {
        showMsg("Failed to render STL.", "error");
      }
    });
  });

  var sbox = "// Parameters\n" +
    "w = {{w}};\n" +
    "l = {{l}};\n" +
    "h = {{h}};\n" +
    "wall_thickness = {{wt}};\n" +
    "lid_thickness = {{lt}};\n" +
    "lid_clearance = 0;\n\n" +
    "// Main box body\n" +
    "module box() {\n" +
    "    difference() {\n" +
    "        cube([w, l, h]);\n" +
    "        translate([wall_thickness, wall_thickness, wall_thickness])\n" +
    "            cube([w - 2 * wall_thickness, l - 2 * wall_thickness, h]);\n" +
    "    }\n" +
    "}\n\n" +
    "// Lid top\n" +
    "module top_l() {\n" +
    "    cube([w, l, lid_thickness/2]);\n" +
    "    translate([w*.5, l, 0])\n" +
    "    cube([10, 2, lid_thickness/2]);\n" +
    "}\n" +
    "// Lid bottom\n" +
    "module bottom_l() {\n" +
    "    difference() {\n" +
    "        cube([(w - (wall_thickness*2))- lid_clearance, (l - (wall_thickness*2))-lid_clearance, lid_thickness/2]);\n" +
    "        translate([wall_thickness, wall_thickness, 0])\n" +
    "        cube([(w - (wall_thickness*4)), (l - (wall_thickness*4)), (lid_thickness/2)+1]);\n" +
    "    }\n" +
    "}\n\n" +
    "box();\n\n" +
    "translate([w*1.1, 0, 0]) {\n" +
    "    top_l();\n" +
    "    translate([wall_thickness, wall_thickness, lid_thickness/2])\n" +
    "    bottom_l();\n" +
    "}\n";

  var rbox = "$fn = 100;\n" +
    "w = {{w}};\n" +
    "l = {{l}};\n" +
    "h = {{h}};\n" +
    "wall_thickness = {{wt}};\n" +
    "lid_thickness = {{lt}};\n" +
    "lid_clearance = 0;\n" +
    "rad = {{cr}};\n\n" +
    "module outer_rec() {\n" +
    "    linear_extrude(height = h)\n" +
    "    offset(r=rad) offset(delta = -1*rad) square([w, l]);\n" +
    "}\n\n" +
    "module inner_rec() {\n" +
    "    linear_extrude(height = h)\n" +
    "    offset(r=rad) offset(delta = -1*rad)\n" +
    "    square([w - (wall_thickness*2), l - (wall_thickness*2)]);\n" +
    "}\n\n" +
    "module top_l() {\n" +
    "    linear_extrude(height = lid_thickness/2)\n" +
    "    offset(r=rad) offset(delta = -1*rad) square([w, l]);\n" +
    "    translate([w*.5, l, 0])\n" +
    "    cube([10, 2, lid_thickness/2]);\n" +
    "}\n" +
    "module bottom_l() {\n" +
    "    difference() {\n" +
    "        linear_extrude(height = lid_thickness/2)\n" +
    "        offset(r=rad) offset(delta = -1*rad)\n" +
    "        square([(w - (wall_thickness*2))- lid_clearance, (l - (wall_thickness*2))-lid_clearance]);\n" +
    "        translate([wall_thickness, wall_thickness, 0])\n" +
    "        linear_extrude(height = (lid_thickness/2)+1)\n" +
    "        offset(r=rad) offset(delta = -1*rad)\n" +
    "        square([(w - (wall_thickness*4)), (l - (wall_thickness*4))]);\n" +
    "    }\n" +
    "}\n\n" +
    "difference() {\n" +
    "    outer_rec();\n" +
    "    translate([wall_thickness, wall_thickness, wall_thickness])\n" +
    "    inner_rec();\n" +
    "}\n\n" +
    "translate([w*1.1, 0, 0]) {\n" +
    "    top_l();\n" +
    "    translate([wall_thickness, wall_thickness, lid_thickness/2])\n" +
    "    bottom_l();\n" +
    "}\n";

  // expose to outer scope of script
  window.sbox = sbox;
  window.rbox = rbox;
});
</script>

<%- include('../partials/footer') %>
