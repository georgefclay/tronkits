        <g>
          <path d="M 270 70 Q 280 50 320 60" fill="none" stroke="#4A5B72" stroke-width="1" stroke-dasharray="3 3" />
          <text x="200" y="60" font-family="JetBrains Mono, monospace" font-size="11" fill="#4A5B72" font-style="italic">→ current flows here</text>
        </g>
        <g>
          <path d="M 220 195 Q 215 160 230 145" fill="none" stroke="#E25C2C" stroke-width="1.2" stroke-dasharray="3 3" />
          <circle cx="220" cy="195" r="3" fill="#E25C2C" />
          <text x="160" y="220" font-family="Space Grotesk, sans-serif" font-size="13" fill="#E25C2C" font-weight="600" font-style="italic">tweak this</text>
          <text x="160" y="236" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A5B72">to dim the LED</text>
        </g>
