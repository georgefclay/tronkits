<% var currentPage = 'home'; %>
<%- include('../partials/header') %>

<section class="tk-hero">
  <div class="tk-status-strip">
    <span>// FILE · home.tron · last updated <%= new Date().toISOString().slice(0,10) %></span>
    <span><span class="pulse"></span>STATUS: SOLDERING_HOT</span>
  </div>

  <div class="tk-hero__grid">
    <div>
      <div class="tk-hero__tags">
        <span class="tk-tag tk-tag--accent">● Beginner-friendly</span>
        <span class="tk-tag">Hands-on</span>
        <span class="tk-tag">Pet projects</span>
      </div>

      <h1 class="tk-h1 tk-h1--xl">
        Solder.<br>
        <span class="accent">Sketch.</span><br>
        <span style="position:relative; display:inline-block">
          Ship.
          <svg width="240" height="20" style="position:absolute; left:0; bottom:-10px" aria-hidden="true">
            <path d="M 4 14 Q 60 4 120 10 T 236 8" fill="none" stroke="#E25C2C" stroke-width="2.5" stroke-linecap="round" />
          </svg>
        </span>
      </h1>

      <p class="tk-lede" style="margin-top:36px; margin-bottom:36px; max-width:480px">
        A workbench for total beginners. Friendly tutorials in <strong style="color:var(--ink)">OpenSCAD</strong>, Raspberry Pi, and basic electronics — plus the calculators you actually need on your bench.
      </p>

      <div class="tk-hero__btns" style="margin-top:0">
        <a href="/tutorials" class="tk-btn tk-btn--accent">Browse Tutorials →</a>
        <a href="/utility" class="tk-btn tk-btn--ghost">Open the toolbox</a>
      </div>

      <div class="tk-stats">
        <div><div class="tk-stats__n">24</div><div class="tk-stats__label">Tutorials</div></div>
        <div><div class="tk-stats__n">06</div><div class="tk-stats__label">Calculators</div></div>
        <div><div class="tk-stats__n">∞</div><div class="tk-stats__label">Side quests</div></div>
      </div>
    </div>

