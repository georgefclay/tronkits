        </g>
      </svg>
      <div class="tk-stamp tk-stamp--green" style="position:absolute; top:24px; right:-20px; transform:rotate(8deg); width:104px; height:104px">
        WELCOME · BENCH · 2026
      </div>
    </div>
  </div>
</section>

<!-- Featured tutorials -->
<section class="tk-section">
  <div class="tk-section-head">
    <div class="tk-section-head__n">01</div>
    <div class="tk-section-head__body">
      <div class="tk-section-head__kicker">// Latest builds</div>
      <h2 class="tk-h2">Tutorials worth your weekend</h2>
    </div>
    <div class="tk-section-head__rule"></div>
  </div>

  <div class="tk-tut-grid">
    <a class="tk-tut-card" href="/tutorials">
      <div class="tk-tut-card__visual tk-graph-paper-mini">
        <svg width="160" height="120" viewBox="0 0 160 120" aria-hidden="true">
          <g stroke="#15263A" stroke-width="1.5" fill="none" stroke-linejoin="round">
            <path d="M 30 70 L 80 50 L 130 70 L 130 100 L 80 120 L 30 100 Z" fill="#EDE5CD" />
            <path d="M 30 70 L 80 90 L 130 70 M 80 90 L 80 120" />
            <path d="M 50 60 L 100 40 L 150 60 L 150 90" fill="#F5EFDD" opacity="0.8" />
            <path d="M 30 70 L 50 60 M 130 70 L 150 60" stroke-dasharray="3 2" />
          </g>
          <text x="80" y="20" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A5B72">w × l × h</text>
        </svg>
      </div>
      <div class="tk-tut-card__body">
        <div class="tk-tut-card__meta-row">
          <span class="tk-tag tk-tag--accent">OPENSCAD</span>
          <span class="tk-tut-card__meta">6 STEPS · ~15 MIN</span>
        </div>
        <h3 class="tk-h3">Build a parametric box</h3>
        <p>The hello-world of OpenSCAD. Walls, lids, and a couple of variables you can poke.</p>
        <div class="tk-tut-card__cta">READ →</div>
      </div>
    </a>

    <a class="tk-tut-card" href="/tutorials">
      <div class="tk-tut-card__visual tk-graph-paper-mini">
        <svg width="160" height="120" viewBox="0 0 160 120" aria-hidden="true">
          <rect x="20" y="25" width="120" height="80" rx="4" fill="#2D8F60" stroke="#15263A" stroke-width="1.5" />
          <rect x="60" y="50" width="40" height="40" fill="#15263A" />
          <text x="80" y="74" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#F5EFDD">BCM</text>
          <% for (var i=0; i<20; i++) { %>
            <rect x="<%= 26 + i*5.5 %>" y="32" width="3" height="8" fill="#E5B043" stroke="#15263A" stroke-width="0.5" />
          <% } %>
          <rect x="120" y="60" width="14" height="12" fill="#888" stroke="#15263A" />
          <rect x="120" y="78" width="14" height="12" fill="#888" stroke="#15263A" />
          <circle cx="28" cy="98" r="3" fill="#F5EFDD" stroke="#15263A" />
          <circle cx="132" cy="98" r="3" fill="#F5EFDD" stroke="#15263A" />
        </svg>
      </div>
      <div class="tk-tut-card__body">
        <div class="tk-tut-card__meta-row">
          <span class="tk-tag tk-tag--green">RASPBERRY PI</span>
          <span class="tk-tut-card__meta">11 STEPS · ~45 MIN</span>
        </div>
        <h3 class="tk-h3">Pi → Node → Nginx, end to end</h3>
        <p>From SD-card image to public website. Includes the firewall bits people forget.</p>
        <div class="tk-tut-card__cta">READ →</div>
      </div>
    </a>

    <a class="tk-tut-card" href="/tutorials">
      <div class="tk-tut-card__visual tk-graph-paper-mini">
        <svg width="170" height="120" viewBox="0 0 170 120" aria-hidden="true">
          <path d="M 20 60 L 50 60" stroke="#15263A" stroke-width="1.5" fill="none" />
          <path d="M 110 60 L 150 60" stroke="#15263A" stroke-width="1.5" fill="none" />
          <polyline points="50,60 56,52 64,68 72,52 80,68 88,52 96,68 104,52 110,60" fill="none" stroke="#15263A" stroke-width="1.5" />
          <text x="80" y="44" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A5B72">R1</text>
          <g transform="translate(150 60)">
            <polygon points="-2,-12 -2,12 14,0" fill="#E25C2C" stroke="#15263A" stroke-width="1.5" stroke-linejoin="round" />
            <line x1="14" y1="-12" x2="14" y2="12" stroke="#15263A" stroke-width="1.5" />
            <path d="M 16 -10 L 22 -16 M 18 -6 L 24 -12 M 20 -2 L 26 -8" stroke="#E25C2C" stroke-width="1.5" stroke-linecap="round" />
          </g>
          <text x="85" y="100" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-style="italic" font-size="13" fill="#4A5B72">"hello, world."</text>
        </svg>
      </div>
      <div class="tk-tut-card__body">
        <div class="tk-tut-card__meta-row">
          <span class="tk-tag tk-tag--blue">ELECTRONICS</span>
          <span class="tk-tut-card__meta">4 STEPS · ~10 MIN</span>
        </div>
        <h3 class="tk-h3">Blink an LED, properly</h3>
        <p>Why you need a resistor. How to pick one. And why your LED keeps dying.</p>
        <div class="tk-tut-card__cta">READ →</div>
      </div>
    </a>
  </div>
</section>

<!-- Utilities preview -->
<section class="tk-band-deep">
  <div class="tk-section-head">
    <div class="tk-section-head__n">02</div>
    <div class="tk-section-head__body">
      <div class="tk-section-head__kicker">// The toolbox</div>
      <h2 class="tk-h2">Calculators that earn their drawer space</h2>
    </div>
    <div class="tk-section-head__rule"></div>
  </div>

  <div class="tk-util-tile-grid">
    <%
      var __homeUtils = [
        { href:'/resistor',        name:'Resistor',        sub:'4·5·6 band decoder',  icon:'resistor', color:'accent' },
        { href:'/555',             name:'555 Timer',       sub:'Astable / Monostable', icon:'ic',       color:'violet' },
        { href:'/voltage-divider', name:'Voltage Divider', sub:'with load option',     icon:'divider',  color:'blue' },
        { href:'/led-resistor',    name:'LED Resistor',    sub:'E-series rounding',    icon:'led',      color:'red' },
        { href:'/passphrases',     name:'Passphrase',      sub:'Memorable + secure',   icon:'lock',     color:'green' },
        { href:'/csv-viewer',      name:'CSV Viewer',      sub:'Preview · filter · export', icon:'csv', color:'copper' }
      ];
      var __colorHex = { accent:'#E25C2C', violet:'#6B47B8', blue:'#2E6DA4', red:'#C9442C', green:'#2D8F60', copper:'#B87333' };
    %>
    <% __homeUtils.forEach(function(u, i){ var c = __colorHex[u.color]; %>
      <a href="<%= u.href %>" class="tk-util-tile">
        <div class="tk-util-tile__top">
          <%- include('../partials/util_icon', { kind: u.icon, color: c }) %>
          <span class="tk-util-tile__idx">0<%= i + 1 %></span>
        </div>
        <h3 class="tk-h3" style="margin-bottom:4px"><%= u.name %></h3>
        <div class="tk-util-tile__sub"><%= u.sub %></div>
        <div class="tk-util-tile__cta" style="color: <%= c %>">OPEN TOOL →</div>
      </a>
    <% }) %>
  </div>
</section>

