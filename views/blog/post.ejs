<% var currentPage = 'blog'; %>
<%- include('../../partials/header') %>

<section class="tk-section">
  <div class="tk-breadcrumb">// HOME / FIELD NOTES / <%= post.title.toUpperCase().slice(0, 40) %></div>

  <article style="max-width:760px; margin:0 auto">
    <a href="/blog" class="tk-mono" style="text-decoration:none; display:inline-block; margin-bottom:24px; color:var(--accent)">← BACK TO BLOG</a>

    <h1 class="tk-h1" style="font-size:56px; margin-bottom:18px"><%= post.title %></h1>
    <div class="tk-mono" style="margin-bottom:32px">
      <%
        var d = post.date;
        var dateStr = d ? (d.toISOString().slice(0,10)) : '';
      %>
      <%= dateStr %> · TRONKITS FIELD NOTES
    </div>

    <div class="tk-prose"><%- post.html %></div>
  </article>
</section>

<%- include('../../partials/footer') %>
